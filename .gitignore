# Python cache
__pycache__/
*.py[cod]
*$py.class

# Build / packaging
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Conda / local env folders
.conda/
conda-meta/

# Jupyter
.ipynb_checkpoints/

# IDE / editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs and temp
*.log
*.tmp
*.bak

# Streamlit secrets 
.streamlit/secrets.toml

# Environment variable files
.env
.env.*
environment.yml

# Large model/data artifacts
checkpoints/
artifacts/
outputs/
*.pt
*.pth
*.onnx
*.tif
*.tiff
*.zip

# Local planning/notes
knowledge_base.txt

# Ignore root-level ad-hoc images
/*.jpg
/*.jpeg
/*.png

# Track app card images from assets folder
!assets/images/
!assets/images/*.jpg
!assets/images/*.jpeg
!assets/images/*.png
